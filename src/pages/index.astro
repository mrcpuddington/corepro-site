---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="CorePro | Coming Soon"
  description="CorePro is building a smarter training experience. Launching soon."
>
  <main class="page">
    <header class="nav">
      <div class="brand">
        <img src="/corepro-logo.png" alt="CorePro logo" class="mark" />
        <span>CorePro</span>
      </div>
      <span class="status">Coming soon</span>
    </header>

    <section class="hero">
      <div class="copy">
        <h1>
          Log workouts<br />
          <span>Get stronger</span><br />
          Stay consistent
        </h1>
        <p class="lead">
          CorePro is a clean training companion for lifters who want fast logging, clear progress, and zero clutter.
        </p>
        <p class="meta">Early access opens soon.</p>
      </div>

      <div class="visual">
        <div class="device-stack">
          <div class="phone phone--back"></div>
          <div class="phone phone--front">
            <div class="screen">
              <div class="pill"></div>
              <div class="row"></div>
              <div class="row short"></div>
              <div class="row"></div>
              <div class="row"></div>
              <div class="row short"></div>
              <div class="cta"></div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .page {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 28px 96px;
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 28px 0 18px;
    border-bottom: 1px solid var(--line);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-weight: 700;
    font-size: 1.05rem;
  }

  .mark {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    box-shadow: 0 8px 22px rgb(30 10 2 / 0.1);
  }

  .status {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .hero {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(32px, 6vw, 80px);
    align-items: center;
    padding-top: clamp(36px, 8vw, 96px);
  }

  h1 {
    margin: 0;
    line-height: 1.02;
    font-family: "Syne", "Trebuchet MS", sans-serif;
    font-size: clamp(2.6rem, 7.5vw, 5rem);
  }

  h1 span {
    color: var(--brand);
  }

  .lead {
    margin: 18px 0 0;
    font-size: clamp(1.02rem, 2.2vw, 1.28rem);
    color: var(--muted);
    max-width: 42ch;
    line-height: 1.5;
  }

  .meta {
    margin: 20px 0 0;
    font-weight: 600;
    color: #2a2a2a;
  }

  .visual {
    display: grid;
    place-items: center;
  }

  .device-stack {
    position: relative;
    width: clamp(220px, 32vw, 340px);
    height: clamp(420px, 64vw, 640px);
  }

  .phone {
    position: absolute;
    inset: 0;
    border-radius: 30px;
    border: 2px solid #e6e6e6;
    background: #ffffff;
    box-shadow: 0 24px 50px rgb(0 0 0 / 0.12);
  }

  .phone--back {
    transform: translate(36px, -20px);
    opacity: 0.25;
  }

  .phone--front {
    z-index: 2;
  }

  .screen {
    position: absolute;
    inset: 16px;
    border-radius: 22px;
    background: linear-gradient(180deg, #f7f7f7 0%, #ffffff 40%);
    padding: 18px;
    display: grid;
    gap: 12px;
  }

  .pill {
    height: 12px;
    width: 60px;
    border-radius: 999px;
    background: #dedede;
  }

  .row {
    height: 14px;
    border-radius: 999px;
    background: #ececec;
  }

  .row.short {
    width: 70%;
  }

  .cta {
    height: 40px;
    border-radius: 12px;
    background: var(--brand);
    margin-top: auto;
  }

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
    }

    .visual {
      order: -1;
    }

    .device-stack {
      width: clamp(200px, 70vw, 320px);
      height: clamp(380px, 92vw, 560px);
      margin-bottom: 24px;
    }
  }

  @media (max-width: 600px) {
    .nav {
      flex-direction: column;
      gap: 10px;
      align-items: flex-start;
    }

    .status {
      letter-spacing: 0.16em;
    }
  }
</style>
